# Local dev only: copy to grid-hub/.dev.vars (gitignored) for POST /rpc testing.
GRID_RPC_TOKEN=dev-grid-rpc-token
# Optional per-world keys (JSON). Required in production (fc#1007 / crew-secrets); when unset
# with GRID_RPC_TOKEN also unset, mutating RPC skips world-key checks (local dev only).
# GRID_WORLD_KEYS={"The Hollow Grid":"dev-hollow-key","Dustfall":"dev-dustfall-key"}
