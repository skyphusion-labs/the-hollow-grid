{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "the-hollow-grid",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-04",
  "observability": {
    "enabled": true
  },
  "vars": {
    // Player names allowed to broadcast with `wall` (comma-separated).
    "ADMINS": "skyphusion",
    // This world's name + public address, advertised to the federation registry.
    // A second world (worlds/dustfall.jsonc) runs this same code under its own
    // name and url, joining the same Grid. (See docs/federation.md.)
    "WORLD_NAME": "The Hollow Grid",
    // The PRODUCTION address this world advertises to the federation registry.
    // Local dev overrides this back to ws://localhost:8787/ws (see scripts/dev.sh
    // and the dev:solo script) so travel handoff works against the dev ports.
    "WORLD_URL": "wss://hollow.skyphusion.org/ws"
  },
  // Bind this world to its public hostname. custom_domain has wrangler create the
  // DNS record + TLS cert in the skyphusion.org zone on deploy. Players connect to
  // wss://hollow.skyphusion.org/ws.
  "routes": [{ "pattern": "hollow.skyphusion.org", "custom_domain": true }],
  "durable_objects": {
    "bindings": [{ "name": "WORLD", "class_name": "World" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["World"] }],
  // The federation backend lives in its own Worker (grid-hub/); we reach it over
  // an RPC service binding to its GridHubService entrypoint. This is what lets a
  // separate deployment share the Grid. (See docs/federation.md.)
  "services": [{ "binding": "GRID", "service": "grid-hub", "entrypoint": "GridHubService" }]
}
