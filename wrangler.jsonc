{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mud-on-cf-workers",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-04",
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      { "name": "WORLD", "class_name": "World" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["World"] }
  ]
}
