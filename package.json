{
  "name": "the-hollow-grid",
  "version": "0.29.9",
  "private": true,
  "description": "A MUD built on Cloudflare Workers + Durable Objects",
  "license": "AGPL-3.0-only",
  "author": "Conrad Rockenhaus",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "start": "bash scripts/dev.sh",
    "dev:solo": "wrangler dev -c wrangler.jsonc -c grid-hub/wrangler.jsonc --var WORLD_URL:ws://localhost:8787/ws",
    "dev:dustfall": "wrangler dev -c worlds/dustfall.jsonc --var WORLD_URL:ws://localhost:8788/ws",
    "deploy": "wrangler deploy -c grid-hub/wrangler.jsonc && wrangler deploy && wrangler deploy -c worlds/dustfall.jsonc",
    "typecheck": "tsc --noEmit && tsc --noEmit -p grid-hub/tsconfig.json",
    "smoke": "node smoke.mjs",
    "connect": "node scripts/connect.mjs",
    "map": "node scripts/render-map.mjs",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^7",
    "wrangler": "^4.108.0"
  }
}
